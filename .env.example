# Configuration docker compose (copier en .env). Le .env est gitignoré.

# Clé API Mistral (obligatoire).
MISTRAL_API_KEY=your-mistral-api-key

# Image à utiliser. Par défaut, image locale construite par `docker compose build`.
# Sur le NAS, pour tirer l'image publiée (GitHub Actions -> GHCR) sans rebuild :
# IMAGE=ghcr.io/emmanuelmathot/100pac-chatbot:latest

# Ports exposés sur l'hôte (NAS).
API_PORT=8000
CHAT_PORT=8501

# Emplacement des artefacts sur l'hôte (générés au préalable).
# Par défaut : copiés dans le dépôt. Sur le NAS, pointez vers un dossier persistant,
# par ex. /volume1/docker/100pac/...
# PAC_ZARR_HOST=./data/pac.zarr
# PAC_CHROMA_HOST=./backend/store/chroma
# PAC_REPORT_HOST=./docs/Performance-PAC-Rapport-final.pdf
